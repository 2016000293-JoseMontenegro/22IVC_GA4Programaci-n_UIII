Algoritmo Lecc34_Act1_Inc3
	Definir cel, fah, kel Como Real
	Escribir 'Nombre: José Montenegro'
	Escribir 'Grado: IVC - Clave = 22'
	Escribir '=====GRADOS===='
	Escribir 'Ingrese la temperatura en grados centigrados:'
	Leer cel
	fah <- (cel*9/5)+32
	kel <- cel+273.15
	Escribir 'Fahrenheit: ', fah
	Escribir 'Celsius: ', cel
	Escribir 'Kelvin: ', kel
FinAlgoritmo
